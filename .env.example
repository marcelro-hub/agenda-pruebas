# Variables de entorno — copiar este archivo como .env y completar los valores
# NO subir el archivo .env a GitHub

# Railway inyecta DATABASE_URL automáticamente cuando conectás el plugin de PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/railway

# En Railway, NODE_ENV se configura como variable de entorno en el dashboard
NODE_ENV=production

# Puerto (Railway también lo inyecta automáticamente — no hace falta cambiarlo)
PORT=3000
